# ============================================================
#  igarateca – Variáveis de Ambiente (Docker)
#  Copie para .env e ajuste os valores.
# ============================================================

# ── Super Admin Inicial ──
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=s3nh@F0rt3!
ADMIN_PHONE=11999999999

# ── Banco de Dados ──
DB_NAME=cnpj_platform
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# ── Redis ──
REDIS_PORT=6379
REDIS_DB=0

# ── PagSeguro ──
PAGSEGURO_EMAIL=seu@email.com
PAGSEGURO_TOKEN=seu_token
PAGSEGURO_SANDBOX=true
PAGSEGURO_APP_ID=app_id
PAGSEGURO_APP_KEY=app_key

# ── JWT ──
JWT_SECRET_KEY=TROQUE-ESTA-CHAVE-POR-ALGO-SEGURO
JWT_REFRESH_SECRET_KEY=TROQUE-ESTA-TAMBEM
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Plataforma ──
LIMITE_CREDITOS_MAXIMO=100000
MODO_FILA_PADRAO=false
TIMEOUT_CONSULTA_SEGUNDOS=30
CHUNK_SIZE_EXPORTACAO=10000

# ── URLs ──
FRONTEND_URL=http://localhost:3000

# ── Ambiente ──
ENVIRONMENT=production

# ── ETL ──
OUTPUT_FILES_PATH=./downloads
EXTRACTED_FILES_PATH=./extracted
# FILES_DATE=          # Deixe vazio p/ auto-detectar mês atual (fallback: mês anterior)
MAX_WORKERS=4
