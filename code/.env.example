# Example .env configuration file for RFB ETL process
# Copy this file to .env and modify the values according to your setup

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Dados_RFB
DB_USER=rfb_user
DB_PASSWORD=rfb_password

# File Paths
OUTPUT_FILES_PATH=./data/downloads
EXTRACTED_FILES_PATH=./data/extracted

# Performance Settings
CHUNK_SIZE=4096
BATCH_SIZE=2000000
MAX_WORKERS=4

# PgAdmin Configuration (for Docker Compose)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=8080

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Processing configuration (true/false)
# Default is true for all if not specified
PROCESS_CNAE=true
PROCESS_MOTI=true
PROCESS_MUNIC=true
PROCESS_NATJU=true
PROCESS_PAIS=true
PROCESS_QUALS=true
PROCESS_EMPRESA=true
PROCESS_ESTABELECIMENTO=true
PROCESS_SOCIOS=true
PROCESS_SIMPLES=true

# Example: To skip processing estabelecimento and socios:
# PROCESS_ESTABELECIMENTO=false
# PROCESS_SOCIOS=false
